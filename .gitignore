# ============================================
# .gitignore для проекта infolake / lake_grok
# Цель: в git попадают файлы из backend/ (кроме секретов) и frontend/
# ============================================

# ----------------------------------------
# Переменные окружения (строго не в git)
# ----------------------------------------
.env
.env.*
*.env
backend/.env
backend/.env.*

# ----------------------------------------
# Python / Django
# ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Django specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
*.sqlite3

# Виртуальные окружения
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/

# ----------------------------------------
# Media (загрузки пользователей и ассеты)
# Полностью игнорируем media/, так как все загруженные файлы
# (маркеры, вложения, иконки событий) теперь не попадают в git.
# При необходимости можно закоммитить отдельные файлы через git add -f
# ----------------------------------------
media/

# ----------------------------------------
# Frontend (Vite + React)
# ----------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/.parcel-cache/
frontend/coverage/

# Логи и локальные файлы фронтенда
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ----------------------------------------
# IDE и редакторы
# ----------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ----------------------------------------
# Операционная система
# ----------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------
# Synology NAS (DSM + Synology Drive + File Station)
# ----------------------------------------
# Исключаем ВСЁ, что создаёт Synology автоматически:
# - @eaDir (превью и extended attributes — появляются во всех папках)
# - Synology Drive метаданные
# - Корзина DSM (#recycle)
# - Временные папки и прочий мусор
#
# Эти правила защищают репозиторий при работе с шарами Synology.

# Extended attributes и превью (появляются рекурсивно в каждой папке)
**/@eaDir/
**/@eaDir/*

# Synology Drive (клиент на ПК и синхронизация)
SynologyWorkingDirectory/
.SynologyDrive/
SynologyDrive/
**/.SynologyDrive/
**/SynologyDrive/

# Другие артефакты Synology
.synology/
.Synology/
**/.synology/
**/.Synology/

# Корзина и временные папки Synology
#recycle/
@tmp/
**/#recycle/
**/@tmp/

# Дополнительные мусорные файлы от Synology
*.syno
*._syno*
**/.Synology*

# ----------------------------------------
# Прочее (корневые файлы, не относящиеся к backend/frontend)
# ----------------------------------------
# Если не планируете коммитить эти папки/файлы:
*.xlsx
*.xlsm
Значки/
Значки событий/

# ----------------------------------------
# TileServer GL (tileserver/)
# ----------------------------------------
# Весь полезный контент tileserver/ публикуется в git:
#   стили (borders-labels.json и др.), шрифты (глифы), скрипты, config.json,
#   data/name-overrides.json, sprites/ и т.д.
#
# Единственное исключение — огромные файлы с тайлами (*.mbtiles).
# Они никогда не должны попадать в git (файлы по 1-90+ ГБ).
#
# docker-compose.yml лежит только в корне проекта (не внутри tileserver/).
# В tileserver/ больше нет отдельного .gitignore — все правила здесь.
# ----------------------------------------

# Полный запрет на .mbtiles (в tileserver/ и везде в проекте)
**/*.mbtiles

# Tar archives (большие оффлайн-архивы Docker, экспорты и т.д.)
# Эти файлы могут весить сотни МБ — ГБ и не должны попадать в git
**/*.tar
**/*.tar.gz
**/*.tgz

# Специфичные для проекта оффлайн-архивы
infolake_full_offline*.tar
infolake_full_offline*.tar.gz
infolake_full_offline*.tgz
offline/infolake_full_offline.tar
offline/python-wheels/

# Дополнительные большие/временные файлы из tileserver setup
tileserver/test_data.zip
tileserver/*.zip
tileserver/terrain.mbtiles

# Артефакты скачиваний и мусор (не должны появляться)
tileserver/curl.exe
tileserver/test_data.zip/
tileserver/$null
tileserver/-L
tileserver/-o

# Дублирующий docker-compose внутри tileserver/ (должен быть только в корне)
tileserver/docker-compose.yml


# ============================================
# Что будет в git (по замыслу):
# - backend/ (весь код, миграции .py, static, media/markers/, media/event_markers/)
# - frontend/ (src/, public/, package.json, vite.config.js и т.д.)
# - requirements.txt, manage.py и т.п.
# ============================================

# (Крупные бинарные файлы и исходные данные игнорируются правилами выше:
#  *.xlsx, **/*.mbtiles, **/*.tar, infolake_full_offline*.tar и т.п.)

# ----------------------------------------
# Локальные копии проекта (не коммитить)
# ----------------------------------------
Прога/
Прога.rar
