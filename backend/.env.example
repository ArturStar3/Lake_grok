# Скопируйте в backend/.env и заполните значения для целевой машины.
# На оффлайн-сервере с Docker Desktop обычно: DB_HOST=host.docker.internal

DB_NAME=infolake_db
DB_USER=infolake
DB_PASSWORD=change_me
DB_HOST=host.docker.internal
DB_PORT=5432

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
