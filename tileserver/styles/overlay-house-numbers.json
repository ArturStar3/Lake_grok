{
  "version": 8,
  "name": "Overlay: House numbers",
  "metadata": {
    "openmaptiles:version": "3.x",
    "infolake:overlay": true
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(0,0,0,0)"
      }
    },
    {
      "id": "housenumber",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "housenumber",
      "minzoom": 17,
      "layout": {
        "text-field": ["get", "housenumber"],
        "text-font": ["Open Sans Regular"],
        "text-size": 10
      },
      "paint": {
        "text-color": "#8a7f6a",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    }
  ]
}
