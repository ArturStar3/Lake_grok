{
  "version": 8,
  "name": "Overlay: Mountain peaks (relief)",
  "metadata": {
    "openmaptiles:version": "3.x",
    "infolake:overlay": true
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "sprite": "basic/sprite",
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(0,0,0,0)"
      }
    },
    {
      "id": "mountain-peak",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "mountain_peak",
      "minzoom": 7,
      "filter": ["all", ["==", "$type", "Point"], ["in", "class", "peak", "volcano"]],
      "layout": {
        "icon-image": ["match", ["get", "class"], "volcano", "volcano_11", "mountain_11"],
        "icon-size": 0.9,
        "icon-allow-overlap": false,
        "text-field": [
          "case",
          ["has", "ele"],
          ["concat", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"], ""], "\n", ["get", "ele"], " м"],
          ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"], ""]
        ],
        "text-font": ["Open Sans Regular"],
        "text-size": 11,
        "text-anchor": "top",
        "text-offset": [0, 0.5],
        "text-max-width": 8,
        "text-optional": true
      },
      "paint": {
        "text-color": "#6b4a3a",
        "text-halo-color": "rgba(255,255,255,0.85)",
        "text-halo-width": 1.5
      }
    }
  ]
}
