{
  "version": 8,
  "name": "Overlay: POI - services, shops & tourism",
  "metadata": {
    "openmaptiles:version": "3.x",
    "infolake:overlay": true
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "sprite": "basic/sprite",
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(0,0,0,0)"
      }
    },
    {
      "id": "poi-services",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 13,
      "filter": [
        "in", "class",
        "restaurant", "cafe", "bar", "beer", "fast_food", "ice_cream", "bakery",
        "grocery", "alcohol_shop", "clothing_store", "shop", "bank", "lodging",
        "museum", "art_gallery", "attraction", "castle", "monument", "zoo",
        "aquarium", "amusement_park", "stadium", "pitch", "golf", "swimming",
        "park", "garden", "playground", "dog_park", "picnic_site", "campsite",
        "drinking_water", "toilet", "information", "laundry", "music", "cinema", "theatre"
      ],
      "layout": {
        "icon-image": ["concat", ["get", "class"], "_11"],
        "icon-size": 0.9,
        "icon-allow-overlap": false,
        "icon-padding": 2,
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 11],
        "text-anchor": "top",
        "text-offset": [0, 0.5],
        "text-max-width": 7,
        "text-optional": true
      },
      "paint": {
        "text-color": "#5a4a3a",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    }
  ]
}
