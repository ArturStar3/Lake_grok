{
  "version": 8,
  "name": "Overlay: Water (hydrography)",
  "metadata": {
    "openmaptiles:version": "3.x",
    "infolake:overlay": true
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(0,0,0,0)"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", "intermittent", 1],
      "paint": {
        "fill-color": [
          "interpolate", ["linear"], ["zoom"],
          0, "#7fb2d4",
          4, "#6fa8cf",
          7, "#5fa0cc",
          12, "#5fa0cc"
        ],
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.75,
          5, 0.85,
          8, 0.95
        ]
      }
    },
    {
      "id": "water-intermittent",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["==", "intermittent", 1],
      "paint": {
        "fill-color": "#8fc0dd",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.35,
          10, 0.5,
          14, 0.6
        ]
      }
    },
    {
      "id": "waterway-river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "minzoom": 5,
      "filter": ["==", "class", "river"],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "#5fa0cc",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.4,
          8, 0.7,
          14, 1
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.6,
          10, 1.4,
          14, 3,
          18, 6,
          20, 9
        ]
      }
    },
    {
      "id": "waterway-stream-canal",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "minzoom": 9,
      "filter": ["in", "class", "stream", "canal", "ditch", "drain"],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "#6fa8cf",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          9, 0.3,
          12, 0.7,
          14, 1
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          9, 0.4,
          14, 1.8,
          18, 3.5,
          20, 5
        ]
      }
    }
  ]
}
