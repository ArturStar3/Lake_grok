{
  "version": 8,
  "name": "Overlay: POI - social infrastructure",
  "metadata": {
    "openmaptiles:version": "3.x",
    "infolake:overlay": true
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "sprite": "basic/sprite",
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(0,0,0,0)"
      }
    },
    {
      "id": "poi-infrastructure",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 12,
      "filter": [
        "in", "class",
        "hospital", "doctor", "dentist", "veterinary", "pharmacy",
        "police", "fire_station", "prison", "embassy", "town_hall", "post",
        "school", "college", "library",
        "place_of_worship", "religious_christian", "religious_jewish", "religious_muslim",
        "cemetery"
      ],
      "layout": {
        "icon-image": ["concat", ["get", "class"], "_11"],
        "icon-size": 0.95,
        "icon-allow-overlap": false,
        "icon-padding": 2,
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 0, 15, 11],
        "text-anchor": "top",
        "text-offset": [0, 0.5],
        "text-max-width": 7,
        "text-optional": true
      },
      "paint": {
        "text-color": "#4a4a4a",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    }
  ]
}
