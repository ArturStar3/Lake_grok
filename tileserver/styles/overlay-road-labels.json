{
  "version": 8,
  "name": "Overlay: Road & street names",
  "metadata": {
    "openmaptiles:version": "3.x",
    "infolake:overlay": true
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(0,0,0,0)"
      }
    },
    {
      "id": "road-name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 11,
      "filter": ["!in", "class", "rail", "transit", "ferry", "aerialway"],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 350,
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"], ["get", "ref"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 10, 16, 13],
        "text-rotation-alignment": "map",
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#6b5b3a",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    }
  ]
}
